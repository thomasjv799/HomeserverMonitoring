# Telegram bot token from @BotFather (see README step "Create the Telegram bot").
# NOTE: the variable is TG_BOT_TOKEN (NOT TELEGRAM_BOT_TOKEN) on purpose —
# Netdata's stock config uses TELEGRAM_BOT_TOKEN internally and sets it to ""
# while loading, which would clobber an identically-named env var.
TG_BOT_TOKEN=123456789:AAExampleReplaceMeWithYourRealToken

# Numeric Telegram chat ID the alerts are sent to (see README "Get your chat ID").
TG_CHAT_ID=123456789
